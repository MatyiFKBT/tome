      "x": 660,
      "y": 170,
      "width": 240,
      "height": 50,
      "strokeColor": "#e8e8e8",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 1,
      "roundness": { "type": 3 },
      "boundElements": [
        { "type": "text", "id": "noseries-text" },
        { "type": "arrow", "id": "arrow-to-noseries" }
