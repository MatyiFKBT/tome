      "height": 0,
      "points": [[0, 0], [136, 0]],
      "strokeColor": "#e8e8e8",
      "strokeWidth": 1,
      "roughness": 1,
      "roundness": { "type": 2 },
      "startBinding": { "elementId": "parser-box", "focus": 0, "gap": 2 },
      "endBinding": { "elementId": "noseries-box", "focus": 0, "gap": 2 },
      "startArrowhead": null,
      "endArrowhead": "arrow"
    },
    {
      "id": "arrow-to-chapters",
      "type": "arrow",
      "x": 522,
      "y": 215,
      "width": 136,
      "height": 90,
      "points": [[0, 0], [68, 45], [136, 90]],
      "strokeColor": "#e8e8e8",
      "strokeWidth": 1,
      "roughness": 1,
      "roundness": { "type": 2 },
      "startBinding": { "elementId": "parser-box", "focus": 0.3, "gap": 2 },
      "endBinding": { "elementId": "chapters-box", "focus": 0, "gap": 2 },
      "startArrowhead": null,
      "endArrowhead": "arrow"
    },
    {
      "id": "label-series-idx",
      "type": "text",
      "x": 490,
      "y": 100,
      "width": 120,
      "height": 28,
      "text": "series + index",
      "fontSize": 16,
      "fontFamily": 1,
      "textAlign": "left",
      "strokeColor": "#e8e8e8"
    },
    {
      "id": "label-no-series",
      "type": "text",
      "x": 560,
      "y": 170,
      "width": 100,
      "height": 28,
      "text": "no series",
      "fontSize": 16,
      "fontFamily": 1,
      "textAlign": "left",
      "strokeColor": "#e8e8e8"
    },
    {
      "id": "label-chapter",
