{
  "type": "excalidraw",
  "version": 2,
  "source": "tome-docs",
  "elements": [
    {
      "id": "filename-box",
      "type": "rectangle",
      "x": 40,
      "y": 170,
      "width": 200,
      "height": 50,
      "strokeColor": "#e8e8e8",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 1,
      "roundness": { "type": 3 },
      "boundElements": [
        { "type": "text", "id": "filename-text" },
        { "type": "arrow", "id": "arrow-to-parser" }
      ]
    },
    {
      "id": "filename-text",
      "type": "text",
      "x": 80,
      "y": 181,
      "width": 120,
      "height": 28,
      "text": "filename.ext",
      "fontSize": 22,
      "fontFamily": 1,
      "textAlign": "center",
      "verticalAlign": "middle",
      "strokeColor": "#e8e8e8",
      "containerId": "filename-box"
    },
    {
      "id": "parser-box",
      "type": "rectangle",
      "x": 360,
      "y": 155,
      "width": 160,
      "height": 80,
      "strokeColor": "#e8e8e8",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1.5,
      "strokeStyle": "dashed",
      "roughness": 1,
      "roundness": { "type": 3 },
      "boundElements": [
        { "type": "text", "id": "parser-text" },
        { "type": "arrow", "id": "arrow-to-parser" },
        { "type": "arrow", "id": "arrow-to-series" },
        { "type": "arrow", "id": "arrow-to-noseries" },
        { "type": "arrow", "id": "arrow-to-chapters" }
