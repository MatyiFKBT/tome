      "strokeColor": "#e8e8e8",
      "strokeWidth": 1,
      "roughness": 1,
      "roundness": { "type": 2 },
      "startBinding": { "elementId": "filename-box", "focus": 0, "gap": 2 },
      "endBinding": { "elementId": "parser-box", "focus": 0, "gap": 2 },
      "startArrowhead": null,
      "endArrowhead": "arrow"
    },
    {
      "id": "arrow-to-series",
      "type": "arrow",
      "x": 522,
      "y": 175,
      "width": 136,
      "height": 90,
      "points": [[0, 0], [68, -45], [136, -90]],
      "strokeColor": "#e8e8e8",
      "strokeWidth": 1,
      "roughness": 1,
      "roundness": { "type": 2 },
      "startBinding": { "elementId": "parser-box", "focus": -0.3, "gap": 2 },
      "endBinding": { "elementId": "series-box", "focus": 0, "gap": 2 },
      "startArrowhead": null,
      "endArrowhead": "arrow"
    },
    {
      "id": "arrow-to-noseries",
