      "x": 640,
      "y": 290,
      "width": 310,
      "height": 80,
      "strokeColor": "#e8e8e8",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 1,
      "roundness": { "type": 3 },
      "boundElements": [
        { "type": "text", "id": "guest-text" },
        { "type": "arrow", "id": "arrow-to-guest" }
      ]
    },
    {
      "id": "guest-text",
      "type": "text",
      "x": 670,
      "y": 301,
      "width": 250,
      "height": 58,
      "text": "Admin books\n+ public libraries",
      "fontSize": 20,
      "fontFamily": 1,
      "textAlign": "center",
      "verticalAlign": "middle",
      "strokeColor": "#e8e8e8",
