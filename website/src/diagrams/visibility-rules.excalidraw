{
  "type": "excalidraw",
  "version": 2,
  "source": "tome-docs",
  "elements": [
    {
      "id": "user-box",
      "type": "rectangle",
      "x": 40,
      "y": 175,
      "width": 220,
      "height": 50,
      "strokeColor": "#e8e8e8",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 1,
      "roundness": { "type": 3 },
      "boundElements": [
        { "type": "text", "id": "user-text" },
        { "type": "arrow", "id": "arrow-to-role" }
      ]
    },
    {
      "id": "user-text",
      "type": "text",
      "x": 80,
      "y": 186,
      "width": 140,
      "height": 28,
      "text": "Logged-in user",
      "fontSize": 22,
      "fontFamily": 1,
      "textAlign": "center",
      "verticalAlign": "middle",
      "strokeColor": "#e8e8e8",
      "containerId": "user-box"
    },
    {
      "id": "role-box",
      "type": "rectangle",
      "x": 380,
      "y": 165,
      "width": 120,
      "height": 70,
      "strokeColor": "#e8e8e8",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1.5,
      "strokeStyle": "dashed",
      "roughness": 1,
      "roundness": { "type": 3 },
      "boundElements": [
        { "type": "text", "id": "role-text" },
        { "type": "arrow", "id": "arrow-to-role" },
        { "type": "arrow", "id": "arrow-to-admin" },
        { "type": "arrow", "id": "arrow-to-member" },
        { "type": "arrow", "id": "arrow-to-guest" }
      ]
    },
    {
      "id": "role-text",
      "type": "text",
      "x": 405,
      "y": 186,
      "width": 70,
      "height": 28,
      "text": "Role?",
      "fontSize": 24,
      "fontFamily": 1,
      "textAlign": "center",
      "verticalAlign": "middle",
      "strokeColor": "#e8e8e8",
      "containerId": "role-box"
    },
    {
      "id": "admin-box",
      "type": "rectangle",
      "x": 640,
      "y": 40,
      "width": 310,
      "height": 70,
      "strokeColor": "#e8e8e8",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 1,
      "roundness": { "type": 3 },
      "boundElements": [
        { "type": "text", "id": "admin-text" },
        { "type": "arrow", "id": "arrow-to-admin" }
      ]
    },
    {
      "id": "admin-text",
      "type": "text",
      "x": 680,
      "y": 61,
