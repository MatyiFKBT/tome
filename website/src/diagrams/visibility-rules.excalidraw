      "x": 262,
      "y": 200,
      "width": 116,
      "height": 0,
      "points": [[0, 0], [116, 0]],
      "strokeColor": "#e8e8e8",
      "strokeWidth": 1,
      "roughness": 1,
      "roundness": { "type": 2 },
      "startBinding": { "elementId": "user-box", "focus": 0, "gap": 2 },
      "endBinding": { "elementId": "role-box", "focus": 0, "gap": 2 },
      "startArrowhead": null,
      "endArrowhead": "arrow"
    },
    {
      "id": "arrow-to-admin",
      "type": "arrow",
      "x": 502,
      "y": 180,
      "width": 136,
      "height": 105,
      "points": [[0, 0], [68, -52], [136, -105]],
      "strokeColor": "#e8e8e8",
      "strokeWidth": 1,
      "roughness": 1,
      "roundness": { "type": 2 },
      "startBinding": { "elementId": "role-box", "focus": -0.3, "gap": 2 },
      "endBinding": { "elementId": "admin-box", "focus": 0, "gap": 2 },
      "startArrowhead": null,
      "endArrowhead": "arrow"
    },
    {
      "id": "arrow-to-member",
      "type": "arrow",
      "x": 502,
      "y": 200,
      "width": 136,
      "height": 0,
      "points": [[0, 0], [136, 0]],
      "strokeColor": "#e8e8e8",
      "strokeWidth": 1,
      "roughness": 1,
      "roundness": { "type": 2 },
      "startBinding": { "elementId": "role-box", "focus": 0, "gap": 2 },
      "endBinding": { "elementId": "member-box", "focus": 0, "gap": 2 },
      "startArrowhead": null,
      "endArrowhead": "arrow"
    },
    {
      "id": "arrow-to-guest",
      "type": "arrow",
      "x": 502,
      "y": 220,
      "width": 136,
      "height": 110,
      "points": [[0, 0], [68, 55], [136, 110]],
      "strokeColor": "#e8e8e8",
      "strokeWidth": 1,
      "roughness": 1,
      "roundness": { "type": 2 },
      "startBinding": { "elementId": "role-box", "focus": 0.3, "gap": 2 },
      "endBinding": { "elementId": "guest-box", "focus": 0, "gap": 2 },
      "startArrowhead": null,
      "endArrowhead": "arrow"
    },
    {
      "id": "label-admin",
      "type": "text",
      "x": 530,
      "y": 105,
      "width": 80,
      "height": 28,
      "text": "admin",
