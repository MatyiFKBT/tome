    },
    {
      "id": "member-box",
      "type": "rectangle",
      "x": 640,
      "y": 160,
      "width": 310,
      "height": 80,
      "strokeColor": "#e8e8e8",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 1,
      "roundness": { "type": 3 },
      "boundElements": [
        { "type": "text", "id": "member-text" },
        { "type": "arrow", "id": "arrow-to-member" }
      ]
    },
    {
      "id": "member-text",
      "type": "text",
      "x": 670,
      "y": 171,
      "width": 250,
