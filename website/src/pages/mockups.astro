---
// Internal page for evaluating landing-page hero + theme demo + interactive
// mockups. Not linked from anywhere; hit /mockups directly. Delete once a
// winning set is picked and the chosen variants are integrated.
import BaseLayout from '../layouts/BaseLayout.astro'
import SiteHeader from '../components/SiteHeader.astro'
import { AnimatedHero } from '../components/mockups/AnimatedHero'
import { ScrollStoryHero } from '../components/mockups/ScrollStoryHero'
import { CountUpHero } from '../components/mockups/CountUpHero'
import { ThemePickerRow } from '../components/mockups/ThemePickerRow'
import { FloatingSwatches } from '../components/mockups/FloatingSwatches'
import { AutoCycleTheme } from '../components/mockups/AutoCycleTheme'
import { SyncAnimation } from '../components/mockups/SyncAnimation'
import { HeatmapFillIn } from '../components/mockups/HeatmapFillIn'
import { CurrentlyReadingCarousel } from '../components/mockups/CurrentlyReadingCarousel'
import { CommandKDemo } from '../components/mockups/CommandKDemo'
import { ComparisonFlip } from '../components/mockups/ComparisonFlip'
import { PixelEReader } from '../components/mockups/PixelEReader'
import { StatsTimelapse } from '../components/mockups/StatsTimelapse'
import { LiveStreakCounter } from '../components/mockups/LiveStreakCounter'
import { RolesVisibilityDemo } from '../components/mockups/RolesVisibilityDemo'
import { PluginInstallFlow } from '../components/mockups/PluginInstallFlow'
---
<style>
  .mockup-stage {
    padding: 32px;
    border-radius: 20px;
    background: color-mix(in oklab, var(--bg), var(--fg) 4%);
    border: 1px dashed color-mix(in oklab, var(--fg), transparent 75%);
    margin-top: 8px;
  }
  .mockup-label {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 4px 10px;
    border-radius: 999px;
    background: var(--accent);
    color: var(--accent-fg);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .mockup-group {
    margin-top: 64px;
    padding-top: 32px;
    border-top: 1px solid var(--border);
  }
</style>
<BaseLayout title="Mockups — internal" description="Landing-page prototypes.">
  <SiteHeader />
  <main class="max-w-4xl mx-auto px-6 pt-32 pb-24 space-y-16">

    <div>
      <p class="text-xs uppercase tracking-widest text-[var(--muted)] mb-2">Internal</p>
      <h1 class="text-3xl font-bold mb-3">Landing-page mockups</h1>
      <p class="text-[var(--muted)] max-w-2xl">
        Three categories. Each section has the prototype and a description of what it sells.
      </p>
    </div>

    {/* ── HEROES (original three) ────────────────────────────── */}
    <div class="mockup-group">
      <h2 class="text-xs uppercase tracking-widest text-[var(--muted)] mb-6">Hero candidates</h2>

      <section>
        <span class="mockup-label">Hero · A</span>
        <h3 class="text-2xl font-bold mb-2 mt-2">Live dashboard (synthetic)</h3>
        <p class="text-sm text-[var(--muted)] mb-6 max-w-xl">Synthetic dashboard mockup with animated counters + growing bars.</p>
        <div class="mockup-stage"><AnimatedHero client:load /></div>
      </section>

      <section class="mt-12">
        <span class="mockup-label">Hero · B</span>
        <h3 class="text-2xl font-bold mb-2 mt-2">Scroll storytelling</h3>
        <p class="text-sm text-[var(--muted)] mb-6 max-w-xl">Library → e-reader → sync → stats narrative.</p>
        <div class="mockup-stage"><ScrollStoryHero client:load /></div>
      </section>

      <section class="mt-12">
        <span class="mockup-label">Hero · C</span>
        <h3 class="text-2xl font-bold mb-2 mt-2">Subtle counters</h3>
        <p class="text-sm text-[var(--muted)] mb-6 max-w-xl">Three count-up cards with hover-tilt.</p>
        <div class="mockup-stage"><CountUpHero client:load /></div>
      </section>
    </div>

    {/* ── THEME DEMOS ─────────────────────────────────────────── */}
    <div class="mockup-group">
      <h2 class="text-xs uppercase tracking-widest text-[var(--muted)] mb-6">Theme demos</h2>

      <section>
        <span class="mockup-label">Theme · A · ✓ pick</span>
        <h3 class="text-2xl font-bold mb-2 mt-2">Pick a theme — preview cards</h3>
        <p class="text-sm text-[var(--muted)] mb-6 max-w-xl">Click a card → entire site retheme animates.</p>
        <div class="mockup-stage"><ThemePickerRow client:load /></div>
      </section>

      <section class="mt-12">
        <span class="mockup-label">Theme · B</span>
        <h3 class="text-2xl font-bold mb-2 mt-2">Floating swatches</h3>
        <p class="text-sm text-[var(--muted)] mb-6 max-w-xl">Smaller footprint, same retheme behaviour.</p>
        <div class="mockup-stage flex"><FloatingSwatches client:load /></div>
      </section>

      <section class="mt-12">
        <span class="mockup-label">Theme · C · hero candidate</span>
        <h3 class="text-2xl font-bold mb-2 mt-2">Auto-cycling dashboard</h3>
        <p class="text-sm text-[var(--muted)] mb-6 max-w-xl">Real dashboard screenshots crossfading through themes. Could be the new hero visual.</p>
        <div class="mockup-stage"><AutoCycleTheme client:load showDots={true} /></div>
      </section>
    </div>

    {/* ── INTERACTIVE / ANIMATED IDEAS ─────────────────────────── */}
    <div class="mockup-group">
      <h2 class="text-xs uppercase tracking-widest text-[var(--muted)] mb-6">More animated / interactive ideas</h2>

      <section>
        <span class="mockup-label">#1 · sync</span>
        <h3 class="text-2xl font-bold mb-2 mt-2">Bidirectional sync between KOReader and the web</h3>
        <p class="text-sm text-[var(--muted)] mb-6 max-w-xl">Sells the differentiator: a position dot moves between the two devices.</p>
        <div class="mockup-stage"><SyncAnimation client:load /></div>
      </section>

      <section class="mt-12">
        <span class="mockup-label">#2 · heatmap</span>
        <h3 class="text-2xl font-bold mb-2 mt-2">365-day heatmap fills in</h3>
        <p class="text-sm text-[var(--muted)] mb-6 max-w-xl">Cells fill cell-by-cell over ~5s. Loops. Sells the stats angle.</p>
        <div class="mockup-stage"><HeatmapFillIn client:load /></div>
      </section>

      <section class="mt-12">
        <span class="mockup-label">#3 · currently reading</span>
        <h3 class="text-2xl font-bold mb-2 mt-2">Carousel of books in progress</h3>
        <p class="text-sm text-[var(--muted)] mb-6 max-w-xl">Auto-rotates through 4 books with animated progress bars.</p>
        <div class="mockup-stage"><CurrentlyReadingCarousel client:load /></div>
      </section>

      <section class="mt-12">
        <span class="mockup-label">#4 · cmd+k</span>
        <h3 class="text-2xl font-bold mb-2 mt-2">Search modal types itself</h3>
        <p class="text-sm text-[var(--muted)] mb-6 max-w-xl">Fake ⌘K modal typing "bersk" → revealing results. Loops.</p>
        <div class="mockup-stage"><CommandKDemo client:load /></div>
      </section>

      <section class="mt-12">
        <span class="mockup-label">#5 · comparison</span>
        <h3 class="text-2xl font-bold mb-2 mt-2">Generic library app vs Tome — flip card</h3>
        <p class="text-sm text-[var(--muted)] mb-6 max-w-xl">Toggle to flip a card between a boring table view and Tome's series-with-arcs view.</p>
        <div class="mockup-stage"><ComparisonFlip client:load /></div>
      </section>

      <section class="mt-12">
        <span class="mockup-label">#6 · pixel e-reader</span>
        <h3 class="text-2xl font-bold mb-2 mt-2">SVG e-reader page-turn</h3>
        <p class="text-sm text-[var(--muted)] mb-6 max-w-xl">Charm. Cycles through pages of A Tale of Two Cities every 3s.</p>
        <div class="mockup-stage"><PixelEReader client:load /></div>
      </section>

      <section class="mt-12">
        <span class="mockup-label">#7 · time-lapse</span>
        <h3 class="text-2xl font-bold mb-2 mt-2">12 months of reading, in 4 seconds</h3>
        <p class="text-sm text-[var(--muted)] mb-6 max-w-xl">Bar chart grows month by month with streak counting up. Sells "gets sharper the more you read".</p>
        <div class="mockup-stage"><StatsTimelapse client:load /></div>
      </section>

      <section class="mt-12">
        <span class="mockup-label">#8 · streak</span>
        <h3 class="text-2xl font-bold mb-2 mt-2">Live-feeling streak counter</h3>
        <p class="text-sm text-[var(--muted)] mb-6 max-w-xl">Pulses every few seconds, occasionally bumps up to simulate a fresh session syncing in.</p>
        <div class="mockup-stage"><LiveStreakCounter client:load /></div>
      </section>

      <section class="mt-12">
        <span class="mockup-label">#9 · roles · interactive</span>
        <h3 class="text-2xl font-bold mb-2 mt-2">Switch role → see filtered library</h3>
        <p class="text-sm text-[var(--muted)] mb-6 max-w-xl">Interactive toggle: admin / member / guest. Books fade out to show server-side visibility rules.</p>
        <div class="mockup-stage"><RolesVisibilityDemo client:load /></div>
      </section>

      <section class="mt-12">
        <span class="mockup-label">#10 · plugin install</span>
        <h3 class="text-2xl font-bold mb-2 mt-2">TomeSync appears in the KOReader menu</h3>
        <p class="text-sm text-[var(--muted)] mb-6 max-w-xl">Cycles through "before / installing / done" showing the plugin entering KOReader's wrench menu.</p>
        <div class="mockup-stage"><PluginInstallFlow client:load /></div>
      </section>
    </div>

  </main>
</BaseLayout>
