---
import BaseLayout from '../layouts/BaseLayout.astro'
import SiteHeader from '../components/SiteHeader.astro'
import reference from '../data/benchmark/reference.json'

// ── Data ──────────────────────────────────────────────────────────────────
const reportModules = import.meta.glob('../data/benchmark/reports/*.json', { eager: true }) as Record<string, { default: any }>
const reports = Object.values(reportModules)
  .map((m) => m.default)
  .sort((a, b) => `${a.date}/${a.id}`.localeCompare(`${b.date}/${b.id}`)) // journey order: before → default → speed
// Default to the serial "Scan-path optimizations" snapshot (the shipping config),
// not the opt-in parallel one — so the headline matches the out-of-box experience.
const defaultReport = reports.find((r) => r.id.includes('optimized'))?.id ?? reports[0]?.id

const TIERS = ['10K', '50K', '100K', '150K']
const COMPETITORS = ['BookOrbit', 'Kavita', 'Stump', 'Grimmory', 'Komga']
const APP_COLORS: Record<string, string> = {
  Tome: 'var(--accent)', BookOrbit: '#3b82f6', Kavita: '#10b981',
  Stump: '#f59e0b', Grimmory: '#ef4444', Komga: '#a855f7',
}

// metric key → how to read Tome (snapshot tier field) and competitors (reference field)
const METRICS = [
  { key: 'throughput', label: 'Throughput', unit: 'books / sec', tome: 'throughput_books_per_s', ref: 'throughput_books_per_s', lowerBetter: false, lineExclude: [] as string[] },
  { key: 'peak_ram',   label: 'Peak RAM',   unit: 'MB',          tome: 'peak_mem_mb',  ref: 'peak_mem_mb',  lowerBetter: true,  lineExclude: ['Grimmory', 'Komga'] },
  { key: 'idle_ram',   label: 'Idle RAM',   unit: 'MB',          tome: 'idle_mem_mb',  ref: 'idle_mem_mb',  lowerBetter: true,  lineExclude: ['Grimmory', 'Komga'] },
  { key: 'time',       label: 'Ingest time',unit: 'seconds',     tome: 'wall_clock_s', ref: 'ingest_time_s',lowerBetter: true,  lineExclude: [] },
  { key: 'cpu',        label: 'CPU (avg)',  unit: '%',           tome: 'cpu_pct',      ref: 'cpu_pct',      lowerBetter: true,  lineExclude: [] },
]

// ── SVG helpers (build-time, no deps) ───────────────────────────────────────
type Pt = { x: number; y: number | null }
type Series = { name: string; color: string; points: Pt[] }

function niceMax(v: number): number { return v > 0 ? Math.ceil((v * 1.1) / 100) * 100 : 100 }
function seriesMax(series: Series[]): number {
  const vals = series.flatMap((s) => s.points.map((p) => p.y)).filter((v): v is number => v != null)
  return vals.length ? Math.max(...vals) : 0
}

function lineChart(series: Series[], xLabels: string[], unit: string) {
  const W = 760, H = 340, padL = 56, padR = 96, padT = 20, padB = 38
  const yMax = niceMax(seriesMax(series))
  const plotW = W - padL - padR, plotH = H - padT - padB, n = xLabels.length
  const xAt = (i: number) => padL + (n === 1 ? plotW / 2 : (i * plotW) / (n - 1))
  const yAt = (v: number) => padT + plotH * (1 - v / yMax)
  let grid = ''
  for (let t = 0; t <= 4; t++) {
    const v = (yMax / 4) * t, y = yAt(v)
    grid += `<line x1="${padL}" y1="${y}" x2="${W - padR}" y2="${y}" stroke="var(--border)"/>`
    grid += `<text x="${padL - 8}" y="${y + 4}" text-anchor="end" font-size="11" fill="var(--muted)">${Math.round(v)}</text>`
  }
  let xax = ''
  xLabels.forEach((lbl, i) => { xax += `<text x="${xAt(i)}" y="${H - padB + 20}" text-anchor="middle" font-size="12" fill="var(--muted)">${lbl}</text>` })
  let lines = ''
  for (const s of series) {
    const pts = s.points.filter((p) => p.y !== null)
    if (!pts.length) continue
    const d = pts.map((p, k) => `${k === 0 ? 'M' : 'L'}${xAt(p.x).toFixed(1)},${yAt(p.y as number).toFixed(1)}`).join(' ')
    lines += `<path d="${d}" fill="none" stroke="${s.color}" stroke-width="2.5" stroke-linejoin="round" stroke-linecap="round"/>`
    for (const p of pts) {
      const cx = xAt(p.x).toFixed(1), cy = yAt(p.y as number).toFixed(1)
      lines += `<circle cx="${cx}" cy="${cy}" r="3.5" fill="${s.color}"/>`
      lines += `<circle cx="${cx}" cy="${cy}" r="12" fill="transparent" pointer-events="all" class="hit" data-tip="${s.name} · ${xLabels[p.x]} · ${p.y} ${unit}"/>`
    }
    const last = pts[pts.length - 1]
    if (last.x === n - 1) lines += `<text x="${(xAt(last.x) + 9).toFixed(1)}" y="${(yAt(last.y as number) + 4).toFixed(1)}" font-size="12" font-weight="700" fill="${s.color}">${s.name}</text>`
  }
  return `<svg viewBox="0 0 ${W} ${H}" class="chart"><text x="${padL - 44}" y="${padT - 5}" font-size="11" fill="var(--muted)">${unit}</text>${grid}${xax}${lines}</svg>`
}

function barChart(bars: { name: string; value: number | null; color: string }[], unit: string) {
  const W = 760, H = 340, padL = 56, padR = 18, padT = 22, padB = 56
  const yMax = niceMax(Math.max(...bars.map((b) => b.value ?? 0)))
  const plotW = W - padL - padR, plotH = H - padT - padB, n = bars.length
  const slot = plotW / n, bw = Math.min(80, slot * 0.55)
  const yAt = (v: number) => padT + plotH * (1 - v / yMax)
  let grid = ''
  for (let t = 0; t <= 4; t++) {
    const v = (yMax / 4) * t, y = yAt(v)
    grid += `<line x1="${padL}" y1="${y}" x2="${W - padR}" y2="${y}" stroke="var(--border)"/>`
    grid += `<text x="${padL - 8}" y="${y + 4}" text-anchor="end" font-size="11" fill="var(--muted)">${Math.round(v)}</text>`
  }
  let rects = ''
  bars.forEach((b, i) => {
    const cx = padL + slot * i + slot / 2
    if (b.value === null) {
      rects += `<text x="${cx}" y="${padT + plotH - 4}" text-anchor="middle" font-size="11" fill="var(--muted)" font-style="italic" data-tip="${b.name}: no data for this tier">n/a</text>`
    } else {
      const y = yAt(b.value), h = padT + plotH - y
      rects += `<rect x="${cx - bw / 2}" y="${y}" width="${bw}" height="${h}" rx="4" fill="${b.color}" data-tip="${b.name} · ${b.value} ${unit}"/>`
      rects += `<text x="${cx}" y="${y - 7}" text-anchor="middle" font-size="12" font-weight="600" fill="var(--fg)">${b.value}</text>`
    }
    rects += `<text x="${cx}" y="${H - padB + 20}" text-anchor="middle" font-size="12" fill="var(--muted)">${b.name}</text>`
  })
  return `<svg viewBox="0 0 ${W} ${H}" class="chart"><text x="${padL - 44}" y="${padT - 6}" font-size="11" fill="var(--muted)">${unit}</text>${grid}${rects}</svg>`
}

// ── Pre-render every (report × metric) line and (report × metric × tier) bar ──
function refVal(app: string, field: string, tier: string): number | null {
  const v = (reference.apps as any)[app]?.[field]?.[tier]
  return v ?? null
}

function buildPanel(rep: any) {
  const byTier: Record<string, any> = Object.fromEntries(rep.tiers.map((t: any) => [t.label, t]))
  const lines: Record<string, string> = {}
  const bars: Record<string, Record<string, string>> = {}
  for (const m of METRICS) {
    const tome: Series = { name: 'Tome', color: APP_COLORS.Tome, points: TIERS.map((l, i) => ({ x: i, y: byTier[l]?.[m.tome] ?? null })) }
    const comp: Series[] = COMPETITORS.filter((a) => !m.lineExclude.includes(a)).map((a) => ({
      name: a, color: APP_COLORS[a], points: TIERS.map((l, i) => ({ x: i, y: refVal(a, m.ref, l) })),
    }))
    lines[m.key] = lineChart([tome, ...comp], TIERS, m.unit)
    bars[m.key] = {}
    for (const tier of TIERS) {
      const b = [
        { name: 'Tome', value: byTier[tier]?.[m.tome] ?? null, color: APP_COLORS.Tome },
        ...COMPETITORS.map((a) => ({ name: a, value: refVal(a, m.ref, tier), color: APP_COLORS[a] })),
      ]
      bars[m.key][tier] = barChart(b, m.unit)
    }
  }
  const t150 = byTier['150K'] ?? {}
  return { rep, lines, bars, tput150: t150.throughput_books_per_s, ram150: t150.peak_mem_mb }
}

const panels = reports.map(buildPanel)
---

<BaseLayout title="Performance benchmark — Tome" description="How Tome ingests large ebook libraries, measured against the r/selfhosted book-server benchmark.">
  <SiteHeader />
  <article class="mx-auto max-w-4xl px-6 pt-28 pb-24">
    <header class="mb-8">
      <p class="mb-3 text-xs font-semibold uppercase tracking-[0.18em] text-[var(--accent)]">Performance</p>
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-5 leading-[1.1]">Ingestion benchmark</h1>
      <p class="text-lg text-[var(--muted)] leading-relaxed max-w-2xl">
        Full-library scan throughput, memory, time, and CPU in a capped 8&nbsp;GB&nbsp;/&nbsp;6&nbsp;CPU container, against the
        <a href={reference.source_url} class="underline decoration-[var(--accent)] underline-offset-2">r/selfhosted book-server benchmark</a>.
        Reproducible — the harness lives in <code>bench/</code>. Competitor numbers are from the reference run on different hardware (see the note below).
      </p>
    </header>

    {/* controls */}
    <div class="mb-6 flex flex-col gap-3">
      {reports.length > 1 && (
        <div class="flex items-center gap-3">
          <label for="report-select" class="text-sm text-[var(--muted)] w-16">Build</label>
          <select id="report-select" class="rounded-md border border-[var(--border)] bg-[var(--card)] px-3 py-1.5 text-sm">
            {reports.map((r) => <option value={r.id} selected={r.id === defaultReport}>{r.date} — {r.label}</option>)}
          </select>
        </div>
      )}
      <div class="flex items-center gap-3 flex-wrap">
        <span class="text-sm text-[var(--muted)] w-16">Metric</span>
        {METRICS.map((m, i) => (
          <button class="bm-metric rounded-md border border-[var(--border)] px-3 py-1.5 text-sm" data-metric={m.key} data-default={i === 0 ? 'true' : undefined}>{m.label}</button>
        ))}
      </div>
      <div class="flex items-center gap-3 flex-wrap">
        <span class="text-sm text-[var(--muted)] w-16">Tier (bars)</span>
        {TIERS.map((t) => (
          <button class="bm-tier rounded-md border border-[var(--border)] px-3 py-1.5 text-sm" data-tier={t} data-default={t === '150K' ? 'true' : undefined}>{t}</button>
        ))}
      </div>
    </div>

    {panels.map((p) => (
      <div class="bm-panel" data-report={p.rep.id} style={p.rep.id === defaultReport ? '' : 'display:none'}>
        <div class="mb-6 rounded-lg border border-[var(--border)] bg-[var(--card)] p-4 text-sm text-[var(--muted)]">
          <strong class="text-[var(--fg)]">{p.rep.label}</strong> · {p.rep.date} · <code>{p.rep.git_sha}</code><br />
          {p.rep.env.chip}, {p.rep.env.runtime}, cage {p.rep.env.cage}
          {p.rep.notes && <p class="mt-2">{p.rep.notes}</p>}
        </div>
        <div class="mb-8 grid grid-cols-2 md:grid-cols-3 gap-4">
          <div class="rounded-lg border border-[var(--border)] bg-[var(--card)] p-5">
            <div class="text-3xl font-bold">{p.tput150 ? Math.round(p.tput150) : '—'}<span class="text-base font-normal text-[var(--muted)]"> bk/s</span></div>
            <div class="mt-1 text-sm text-[var(--muted)]">Throughput @ 150K</div>
          </div>
          <div class="rounded-lg border border-[var(--border)] bg-[var(--card)] p-5">
            <div class="text-3xl font-bold">{p.ram150 ?? '—'}<span class="text-base font-normal text-[var(--muted)]"> MB</span></div>
            <div class="mt-1 text-sm text-[var(--muted)]">Peak RAM @ 150K</div>
          </div>
          <div class="rounded-lg border border-[var(--border)] bg-[var(--card)] p-5">
            <div class="text-3xl font-bold">150K<span class="text-base font-normal text-[var(--muted)]"> ✓</span></div>
            <div class="mt-1 text-sm text-[var(--muted)]">Largest tier completed</div>
          </div>
        </div>

        <h2 class="text-xl font-semibold mb-1 bm-metric-title">Across library sizes</h2>
        <p class="text-[var(--muted)] mb-3 text-sm bm-line-note"></p>
        {METRICS.map((m) => (
          <div class="bm-line chart-wrap" data-report={p.rep.id} data-metric={m.key} style="display:none" set:html={p.lines[m.key]} />
        ))}

        <h2 class="text-xl font-semibold mt-10 mb-1 bm-bar-title">Head-to-head at one tier</h2>
        <p class="text-[var(--muted)] mb-3 text-sm">Use the tier buttons above. <strong class="text-[var(--fg)]">n/a</strong> = the app did not finish that tier in the reference run.</p>
        {METRICS.map((m) => TIERS.map((t) => (
          <div class="bm-bar chart-wrap" data-report={p.rep.id} data-metric={m.key} data-tier={t} style="display:none" set:html={p.bars[m.key][t]} />
        )))}
      </div>
    ))}

    <section class="mt-12 rounded-lg border border-[var(--border)] bg-[var(--card)] p-6">
      <h2 class="text-xl font-semibold mb-3">Read this before quoting the numbers</h2>
      <ul class="space-y-3 text-sm text-[var(--muted)] leading-relaxed">
        <li><strong class="text-[var(--fg)]">Different hardware & runtime.</strong> {reference.caveat}</li>
        <li><strong class="text-[var(--fg)]">Coverless synthetic files.</strong> The test EPUBs are ~1.8&nbsp;KB with no cover image, so cover/thumbnail processing runs for no app — including Tome. Real multi-MB books with covers ingest slower for everyone; these are best-case figures.</li>
        <li><strong class="text-[var(--fg)]">Architecture, disclosed.</strong> Tome commits each scan in one SQLite transaction — fast for this workload, with the trade-off of single-writer concurrency. Not magic; a deliberate choice.</li>
      </ul>
    </section>
  </article>

  <style>
    .chart-wrap { width: 100%; border: 1px solid var(--border); border-radius: 12px; background: var(--card); padding: 12px; }
    .chart { width: 100%; height: auto; display: block; }
    .bm-metric, .bm-tier { color: var(--muted); transition: all .12s; }
    .bm-metric[aria-pressed="true"], .bm-tier[aria-pressed="true"] {
      background: var(--accent); color: var(--accent-fg); border-color: var(--accent); font-weight: 600;
    }
  </style>
  <style is:global>
    .chart .hit { cursor: pointer; }
  </style>

  <script>
    import { attachChartTooltip } from '../lib/chartTooltip'

    const NOTES: Record<string, string> = {
      throughput: 'Books ingested per second — higher is better.',
      peak_ram: 'Peak RAM during ingestion — lower is better. Grimmory & Komga (2.5–5 GB) omitted from this line; see the bars.',
      idle_ram: 'Steady-state RAM after ingestion — lower is better. The number that matters for always-on. Grimmory & Komga omitted; see the bars.',
      time: 'Total wall-clock to ingest the whole library — lower is better.',
      cpu: 'Average CPU during ingestion. Read alongside throughput, not on its own — Tome pegs ~1 core (docker reports 100% = one core) but finishes far sooner, so it spends much less total CPU-time than apps sitting at a lower % for much longer.',
    }

    let report = (document.getElementById('report-select') as HTMLSelectElement | null)?.value
      || document.querySelector<HTMLElement>('.bm-panel')?.dataset.report || ''
    let metric = document.querySelector<HTMLElement>('.bm-metric[data-default]')?.dataset.metric || 'throughput'
    let tier = document.querySelector<HTMLElement>('.bm-tier[data-default]')?.dataset.tier || '150K'

    function render() {
      document.querySelectorAll<HTMLElement>('.bm-panel').forEach((el) => { el.style.display = el.dataset.report === report ? '' : 'none' })
      document.querySelectorAll<HTMLElement>('.bm-line').forEach((el) => { el.style.display = (el.dataset.report === report && el.dataset.metric === metric) ? '' : 'none' })
      document.querySelectorAll<HTMLElement>('.bm-bar').forEach((el) => { el.style.display = (el.dataset.report === report && el.dataset.metric === metric && el.dataset.tier === tier) ? '' : 'none' })
      document.querySelectorAll<HTMLElement>('.bm-metric').forEach((b) => b.setAttribute('aria-pressed', String(b.dataset.metric === metric)))
      document.querySelectorAll<HTMLElement>('.bm-tier').forEach((b) => b.setAttribute('aria-pressed', String(b.dataset.tier === tier)))
      const note = NOTES[metric] || ''
      document.querySelectorAll<HTMLElement>('.bm-line-note').forEach((el) => { el.textContent = note })
    }

    document.getElementById('report-select')?.addEventListener('change', (e) => { report = (e.target as HTMLSelectElement).value; render() })
    document.querySelectorAll<HTMLElement>('.bm-metric').forEach((b) => b.addEventListener('click', () => { metric = b.dataset.metric!; render() }))
    document.querySelectorAll<HTMLElement>('.bm-tier').forEach((b) => b.addEventListener('click', () => { tier = b.dataset.tier!; render() }))

    render()
    attachChartTooltip(document.querySelector('article'))
  </script>
</BaseLayout>
