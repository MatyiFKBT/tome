---
import BaseLayout from '../../layouts/BaseLayout.astro'
import SiteHeader from '../../components/SiteHeader.astro'

const posts = [
  {
    slug: 'building-a-koreader-plugin',
    title: 'Building a KOReader plugin from scratch',
    date: '2026-05-25',
    readTime: '10 min read',
    summary: 'Why I built my own .koplugin instead of using KOSync, how KOReader plugins actually work, the gotchas that cost me days, and what it unlocked for Tome.',
  },
]
---
<BaseLayout title="Blog — Tome" description="Technical writing about building a self-hosted ebook library.">
  <SiteHeader />

  <div class="blog-index">
    <header class="relative max-w-3xl mx-auto px-6 pt-32 pb-12 text-center">
      <div class="accent-glow"></div>
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-4">Blog</h1>
      <p class="text-lg text-[var(--muted)]">Technical writing about building Tome.</p>
    </header>

    <div class="max-w-2xl mx-auto px-6 pb-24">
      {posts.map(post => (
        <a href={`/blog/${post.slug}`} class="blog-post-card">
          <div class="blog-post-meta"><time class="blog-post-date">{post.date}</time><span class="blog-post-date">&middot;</span><span class="blog-post-date">{post.readTime}</span></div>
          <h2 class="blog-post-title">{post.title}</h2>
          <p class="blog-post-summary">{post.summary}</p>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .blog-post-card {
    display: block;
    padding: 24px;
    border-radius: 12px;
    border: 1px solid var(--border);
    background: var(--card);
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .blog-post-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 32px -8px var(--accent-soft);
  }
  .blog-post-meta {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .blog-post-date {
    font-size: 0.78rem;
    color: var(--muted);
    font-family: 'JetBrains Mono', monospace;
  }
  .blog-post-title {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--fg);
    margin: 6px 0 8px;
    letter-spacing: -0.01em;
  }
  .blog-post-summary {
    font-size: 0.95rem;
    color: var(--muted);
    line-height: 1.6;
  }
</style>
